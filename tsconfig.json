{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["@playwright/test", "node"]
  },
  "include": [
    "tests/**/*.ts",
    "POM/**/*.ts",
    "playwright.config.ts"
  ]
}
